{
  "name": "@yoda.digital/mycelium",
  "version": "0.1.1",
  "description": "End-to-end encrypted messaging between Claude Code instances. Curve25519 PFS, Ed25519 TOFU, replay protection, stateless relay.",
  "type": "module",
  "main": "build/peer-channel.js",
  "bin": {
    "mycelium-peer": "build/peer-channel.js",
    "mycelium-relay": "build/relay.js"
  },
  "files": [
    "build",
    "README.md",
    "INSTALL.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "bun": ">=1.3.5"
  },
  "scripts": {
    "build": "bun build relay.ts peer-channel.ts --outdir build --target bun --banner '#!/usr/bin/env bun' && chmod +x build/relay.js build/peer-channel.js",
    "test": "bun run test.ts",
    "typecheck": "bunx tsc --noEmit",
    "relay": "bun run relay.ts",
    "peer": "bun run peer-channel.ts"
  },
  "homepage": "https://opensource.yoda.digital/en/projects/mycelium/",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/yoda-digital/mycelium.git"
  },
  "bugs": {
    "url": "https://github.com/yoda-digital/mycelium/issues"
  },
  "license": "MIT",
  "author": "Yoda Digital <dev.ungheni@gmail.com>",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-code",
    "agent-coordination",
    "e2e-encryption",
    "ed25519",
    "curve25519",
    "libsodium",
    "tofu",
    "bun"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "libsodium-wrappers-sumo": "^0.8.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
